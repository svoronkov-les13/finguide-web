# Default production/demo API is the real Spring backend behind nginx:
# VITE_FINGUIDE_API_BASE_URL=/finguide-api/api/v1

# Optional: force the old local in-memory UI mock instead of backend calls.
# VITE_FINGUIDE_USE_MOCK=true

# Optional: point generated client back to the legacy Java mock route for transition checks.
# VITE_FINGUIDE_API_BASE_URL=/finguide-mock/api/v1
# VITE_FINGUIDE_BEARER_TOKEN=mock-access-token-java21

# Optional Keycloak OIDC Authorization Code + PKCE integration.
# Keep disabled for demo/H2 mode until Keycloak is deployed.
# VITE_FINGUIDE_AUTH_ENABLED=true
# VITE_FINGUIDE_OIDC_ISSUER_URL=http://66.42.121.18/auth/realms/finguide
# VITE_FINGUIDE_OIDC_CLIENT_ID=finguide-web
# VITE_FINGUIDE_OIDC_SCOPE=openid profile email
