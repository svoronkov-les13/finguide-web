# Default production/demo API is the real Spring backend behind Kubernetes ingress:
# VITE_FINGUIDE_API_BASE_URL=/finguide-api/api/v1

# Public deployment is served under /fg/; / redirects there.
# VITE_FINGUIDE_BASE_PATH=/fg/

# Optional: force the old local in-memory UI mock instead of backend calls.
# VITE_FINGUIDE_USE_MOCK=true

# Optional: dev server tries the backend first, then falls back to the local mock plan
# when the backend/proxy is unavailable. Set to false to expose API failures directly.
# VITE_FINGUIDE_DEV_MOCK_FALLBACK=false

# Vite dev proxy target — backend base URL (no trailing slash).
# Used by vite.config.ts to proxy /finguide-api/* and /auth/* in local dev.
# In prod this is handled by Kubernetes ingress; this variable has no effect on the built bundle.
# VITE_FINGUIDE_BACKEND_URL=http://localhost:8080

# Optional: point generated client back to the legacy Java mock route for transition checks.
# VITE_FINGUIDE_API_BASE_URL=/finguide-mock/api/v1
# VITE_FINGUIDE_BEARER_TOKEN=mock-access-token-java21

# Optional Keycloak OIDC Authorization Code + PKCE integration.
# Current public issuer:
# VITE_FINGUIDE_AUTH_ENABLED=true
# VITE_FINGUIDE_OIDC_ISSUER_URL=https://finguide.les13.tech/auth/realms/finguide
# VITE_FINGUIDE_OIDC_CLIENT_ID=finguide-web
# VITE_FINGUIDE_OIDC_SCOPE=openid profile email
