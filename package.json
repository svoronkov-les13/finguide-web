{
  "name": "finguide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.6",
  "engines": {
    "node": "22.22.1",
    "bun": "1.3.6"
  },
  "scripts": {
    "dev": "bash scripts/with-node.sh vite --host 0.0.0.0",
    "typecheck": "bash scripts/with-node.sh tsc -b",
    "build": "bun run typecheck && bash scripts/with-node.sh vite build",
    "preview": "bash scripts/with-node.sh vite preview --host 0.0.0.0",
    "lint": "bash scripts/with-node.sh eslint .",
    "test": "bash scripts/with-node.sh vitest run",
    "test:ui": "bash scripts/with-node.sh vitest --ui",
    "e2e": "bash scripts/with-node.sh playwright test"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.16",
    "@tanstack/react-query": "^5.100.5",
    "@tanstack/react-query-devtools": "^5.100.5",
    "@tanstack/react-router": "^1.168.24",
    "@tanstack/react-router-devtools": "^1.166.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.548.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.74.0",
    "recharts": "^3.3.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.16",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.1.12",
    "vitest": "^4.1.5"
  }
